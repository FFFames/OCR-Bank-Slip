# ============================================
# OCR Bank - Git Ignore Configuration
# ============================================

# --------------------------------------------
# Python
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
*.pyc
*.pyo

# --------------------------------------------
# Node / Frontend
# --------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/

# --------------------------------------------
# Environment Variables (IMPORTANT!)
# --------------------------------------------
.env
.env.local
.env.*.local
.env.production

# --------------------------------------------
# IDE & Editors
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*
.spyderproject
.spyproject

# --------------------------------------------
# Logs & Temporary Files
# --------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock
*.pid.*

# --------------------------------------------
# Database Files
# --------------------------------------------
*.db
*.sqlite3
*.sqlite

# --------------------------------------------
# Uploads & User Data (IMPORTANT!)
# --------------------------------------------
backend/uploads/*
backend/images/*
backend/backend/images/*
!backend/uploads/.gitkeep
!backend/images/.gitkeep

# --------------------------------------------
# Vector Store & AI Models
# --------------------------------------------
backend/data/chromadb/*
*.paddleocr
*.onnx

# --------------------------------------------
# Credentials & Secrets (IMPORTANT!)
# --------------------------------------------
backend/config/credentials.json
*secret*.json
*credentials*.json
*.pem
*.key

# --------------------------------------------
# Build Output
# --------------------------------------------
frontend/dist/
frontend/build/
*.tsbuildinfo

# --------------------------------------------
# Git Worktrees (isolated development)
# --------------------------------------------
.worktrees/
worktrees/

# --------------------------------------------
# Claude Code
# --------------------------------------------
.claude/settings.local.json

# --------------------------------------------
# Qodo (Code Review)
# --------------------------------------------
.qodo/

# --------------------------------------------
# Railway (Deployment)
# --------------------------------------------
.railway/

# --------------------------------------------
# Debug Files
# --------------------------------------------
debug_*.jpg
debug_*.png
debug_*.log
server.log
server.pid
backend.log
