# ============================================
# OCR Bank - Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# PostgreSQL database connection URL
DATABASE_URL=postgresql://ocr_bank_user:ocr_bank_password@localhost:5432/ocr_bank
POSTGRES_USER=ocr_bank_user
POSTGRES_PASSWORD=ocr_bank_password
POSTGRES_DB=ocr_bank

# --------------------------------------------
# OCR Configuration
# --------------------------------------------
# OCR language: th (Thai), en (English), or both
OCR_LANGUAGE=th
# Device for OCR processing: cpu or gpu (requires CUDA)
OCR_DEVICE=cpu

# --------------------------------------------
# LLM Configuration
# --------------------------------------------
# Primary LLM Provider: gemini, groq, or local
LLM_PROVIDER=gemini

# Gemini API (Google Generative AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (alternative LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# Local LLM (LM Studio or compatible OpenAI API)
LOCAL_LLM_URL=http://localhost:1234/v1

# --------------------------------------------
# Vector Store (for RAG/Chatbot)
# --------------------------------------------
# ChromaDB persistent storage directory
CHROMADB_PERSIST_DIRECTORY=./data/chromadb

# --------------------------------------------
# Google Sheets Integration (Optional)
# --------------------------------------------
# Path to Google Sheets API credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_PATH=./config/credentials.json
# Your Google Spreadsheet ID
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# --------------------------------------------
# File Storage
# --------------------------------------------
# Directory to store uploaded receipt images
IMAGE_STORAGE_PATH=./images
# Maximum upload size in bytes (10MB default)
MAX_UPLOAD_SIZE=10485760

# --------------------------------------------
# API Server Configuration
# --------------------------------------------
# Host to bind the API server to
API_HOST=0.0.0.0
# Port for the API server
API_PORT=8000
# Enable debug mode (set to False in production)
DEBUG=True
